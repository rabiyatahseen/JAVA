5.Create methods for area and volume in 2. Also create getters and setters.
class Rectangle {

    protected int length;
    protected int breadth;

    // Constructor
    Rectangle(int l, int b) {

        length = l;
        breadth = b;
    }

    // Getters
    int getLength() {

        return length;
    }

    int getBreadth() {

        return breadth;
    }

    // Setters
    void setLength(int l) {

        length = l;
    }

    void setBreadth(int b) {

        breadth = b;
    }

    // Area of Rectangle
    int area() {

        return length * breadth;
    }
}

// Cuboid inherits Rectangle
class Cuboid extends Rectangle {

    private int height;

    // Constructor
    Cuboid(int l, int b, int h) {

        super(l, b);

        height = h;
    }

    // Getter
    int getHeight() {

        return height;
    }

    // Setter
    void setHeight(int h) {

        height = h;
    }

    // Volume of Cuboid
    int volume() {

        return length * breadth * height;
    }
}

class Main {

    public static void main(String[] args) {

        Cuboid c = new Cuboid(10, 5, 4);

        // Using getters
        System.out.println("Length = " + c.getLength());
        System.out.println("Breadth = " + c.getBreadth());
        System.out.println("Height = " + c.getHeight());

        // Methods
        System.out.println("Area of Rectangle = " + c.area());
        System.out.println("Volume of Cuboid = " + c.volume());

        // Using setters
        c.setLength(12);
        c.setBreadth(6);
        c.setHeight(5);

        System.out.println();

        System.out.println("Updated Length = " + c.getLength());
        System.out.println("Updated Breadth = " + c.getBreadth());
        System.out.println("Updated Height = " + c.getHeight());

        System.out.println("Updated Area = " + c.area());
        System.out.println("Updated Volume = " + c.volume());
    }
}
Output
Length = 10
Breadth = 5
Height = 4
Area of Rectangle = 50
Volume of Cuboid = 200

Updated Length = 12
Updated Breadth = 6
Updated Height = 5
Updated Area = 72
Updated Volume = 360

