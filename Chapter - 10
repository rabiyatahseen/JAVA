1.Create a class Animal and derive other class Dog from it.
class Animal {

    void eat() {

        System.out.println("Animal is eating");
    }
}

// Dog class derived from Animal
class Dog extends Animal {

    void bark() {

        System.out.println("Dog is barking");
    }
}

class Main {

    public static void main(String[] args) {

        Dog d = new Dog();

        d.eat();   // inherited method
        d.bark();  // Dog class method
    }
}
Output
Animal is eating
Dog is barking

2.Create a class Circle and use inheritance to create another class Cylinder from it.
class Circle {

    protected int radius;

    // Constructor for Circle
    Circle(int r) {

        radius = r;
    }

    // Area of Circle
    double area() {

        return 3.14 * radius * radius;
    }
}

// Cylinder class inherits Circle
class Cylinder extends Circle {

    private int height;

    // Constructor for Cylinder
    Cylinder(int r, int h) {

        super(r);   // calls Circle constructor
        height = h;
    }

    // Volume of Cylinder
    double volume() {

        return 3.14 * radius * radius * height;
    }
}

class Main {

    public static void main(String[] args) {

        Cylinder c = new Cylinder(7, 14);

        System.out.println("Circle Area = " + c.area());

        System.out.println("Cylinder Volume = " + c.volume());
    }
}
Output
Circle Area = 153.86
Cylinder Volume = 2154.04

3.Create a class Rectangle and use inheritance to create another class Cubeoid. Try to keep it as close to real-world scenario as possible.
class Rectangle {

    protected int length;
    protected int breadth;

    // Constructor for Rectangle
    Rectangle(int l, int b) {

        length = l;
        breadth = b;
    }

    // Area of Rectangle
    int area() {

        return length * breadth;
    }
}

// Cuboid class inherits Rectangle
class Cuboid extends Rectangle {

    private int height;

    // Constructor for Cuboid
    Cuboid(int l, int b, int h) {

        super(l, b);

        height = h;
    }

    // Volume of Cuboid
    int volume() {

        return length * breadth * height;
    }
}

class Main {

    public static void main(String[] args) {

        Cuboid c = new Cuboid(10, 5, 4);

        System.out.println("Rectangle Area = " + c.area());

        System.out.println("Cuboid Volume = " + c.volume());
    }
}
Output
Rectangle Area = 50
Cuboid Volume = 200

