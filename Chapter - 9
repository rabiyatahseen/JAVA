6.Overload a constructor used to initialize a rectangle of length 4 and breadth 5 for using custom parameters.
class Rectangle {

    private int length;
    private int breadth;

    // Default constructor
    Rectangle() {

        length = 4;
        breadth = 5;
    }

    // Overloaded constructor
    Rectangle(int l, int b) {

        length = l;
        breadth = b;
    }

    // Area
    int area() {

        return length * breadth;
    }

    // Perimeter
    int perimeter() {

        return 2 * (length + breadth);
    }

    void display() {

        System.out.println("Length = " + length);
        System.out.println("Breadth = " + breadth);
        System.out.println("Area = " + area());
        System.out.println("Perimeter = " + perimeter());
    }
}

class Main {

    public static void main(String[] args) {

        // Default constructor
        Rectangle r1 = new Rectangle();

        System.out.println("Rectangle 1");
        r1.display();

        System.out.println();

        // Overloaded constructor
        Rectangle r2 = new Rectangle(10, 6);

        System.out.println("Rectangle 2");
        r2.display();
    }
}
Output
Rectangle 1
Length = 4
Breadth = 5
Area = 20
Perimeter = 18

Rectangle 2
Length = 10
Breadth = 6
Area = 60
Perimeter = 32

7.Repeat one for a sphere.
class Sphere {

    private int radius;

    // Setter for radius
    void setRadius(int r) {

        radius = r;
    }

    // Getter for radius
    int getRadius() {

        return radius;
    }

    // Surface Area
    double surfaceArea() {

        return 4 * 3.14 * radius * radius;
    }

    // Volume
    double volume() {

        return (4.0 / 3.0) * 3.14 * radius * radius * radius;
    }
}

class Main {

    public static void main(String[] args) {

        Sphere s = new Sphere();

        // Using setter
        s.setRadius(7);

        // Using getter
        System.out.println("Radius = " + s.getRadius());

        System.out.println("Surface Area = " + s.surfaceArea());
        System.out.println("Volume = " + s.volume());
    }
}
Output
Radius = 7
Surface Area = 615.44
Volume = 1436.0266666666666
