# 3. Square Class

class Square {

    int side;

    int area() {
        return side * side;
    }

    int perimeter() {
        return 4 * side;
    }

    public static void main(String[] args) {

        Square s = new Square();

        s.side = 5;

        System.out.println("Area = " + s.area());
        System.out.println("Perimeter = " + s.perimeter());
    }
}
```

