3.Write a program to find whether a given integer is present in an array or not.
class Main {
    public static void main(String[] args) {

        int[] arr = {1, 2, 3, 4, 5};

        int search = 3;

        boolean found = false;

        for(int i = 0; i < arr.length; i++) {

            if(arr[i] == search) {

                found = true;
            }
        }

        if(found)
            System.out.println("Present");
        else
            System.out.println("Not Present");
    }
}
