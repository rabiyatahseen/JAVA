4.Calculate the average marks from an array containing marks of all students in physics using for-each loop.
class Main {
    public static void main(String[] args) {

        int[] marks = {80, 75, 90, 85, 70};

        int sum = 0;

        // for-each loop
        for(int m : marks) {

            sum = sum + m;
        }

        float average = (float)sum / marks.length;

        System.out.println("Average = " + average);
    }
}
Output
Average = 80.0

5.Create a Java program to add two matrices of size 2x3.
class Main {
    public static void main(String[] args) {

        int[][] A = {
            {1, 2, 3},
            {4, 5, 6}
        };

        int[][] B = {
            {7, 8, 9},
            {1, 2, 3}
        };

        int[][] sum = new int[2][3];

        // Add matrices
        for(int i = 0; i < 2; i++) {

            for(int j = 0; j < 3; j++) {

                sum[i][j] = A[i][j] + B[i][j];
            }
        }

        // Print result
        for(int i = 0; i < 2; i++) {

            for(int j = 0; j < 3; j++) {

                System.out.print(sum[i][j] + " ");
            }

            System.out.println();
        }
    }
}
Output
8 10 12
5 7 9

