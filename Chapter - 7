8.Write a Java program to repeat 4 using recursion.
public class Main {

    // Recursive function
    static void repeatFour(int n) {

        // Base condition
        if (n == 0) {
            return;
        }

        System.out.println(4);

        // Recursive call
        repeatFour(n - 1);
    }

    public static void main(String[] args) {

        // Print 4 five times
        repeatFour(5);
    }
}
